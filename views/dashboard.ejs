<!DOCTYPE html>
<html>
<head>
    <title>Expense Dashboard</title>
    <style>
        body { font-family: Arial; margin: 20px; }
        .container { max-width: 1200px; margin: 0 auto; }
        .summary { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; }
        .summary-box { background: #f0f0f0; padding: 20px; border-radius: 8px; }
        .summary-box h3 { margin: 0; color: #666; }
        .summary-box .amount { font-size: 2em; color: #333; margin: 10px 0; }
        .actions { margin: 20px 0; }
        .btn { padding: 10px 20px; background: #007bff; color: white; text-decoration: none; border-radius: 5px; display: inline-block; margin-right: 10px; }
        .btn-danger { background: #dc3545; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        table th, table td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
        table th { background: #f0f0f0; }
        .category-tag { display: inline-block; background: #e9ecef; padding: 5px 10px; border-radius: 3px; }
        .warning { color: #dc3545; font-weight: bold; }
    </style>
</head>
<body>
    <div class="container">
        <h1>💰 Expense Tracker</h1>
        <div class="actions">
            <a href="/dashboard/expenseForm" class="btn">+ Add Expense</a>
            <a href="/dashboard/budgetForm" class="btn">+ Add Budget</a>
            <a href="/logout" class="btn btn-danger">Logout</a>
        </div>

        <div class="summary">
            <div class="summary-box">
                <h3>Total Spent This Month</h3>
                <div class="amount">$<%= totalSpent.toFixed(2) %></div>
            </div>
            
            <div class="summary-box">
                <h3>Expenses</h3>
                <div class="amount"><%= expenses.length %></div>
            </div>
            
            <div class="summary-box">
                <h3>Budget Money Left</h3>
                    <% for (const category in budgetCategoryTotals) { %>
                        <div class="amount">
                            <%= category %>: $<%= budgetCategoryTotals[category] %> left
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div class="summary-box">
                <h3>Total Budgets</h3>
                <div class="amount"><%= budgets.length %></div>
            </div>
            
        </div>

        <h2>Expenses for <%= currentMonth %></h2>
        <% if (expenses.length > 0) { %>
            <table>
                <tr>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Amount</th>
                    <th>Actions</th>
                </tr>
                <% expenses.forEach(expense => { %>
                    <tr>
                        <td><%= new Date(expense.date).toLocaleDateString() %></td>
                        <td><%= expense.description %></td>
                        <td><span class="category-tag"><%= expense.category %></span></td>
                        <td>$<%= expense.amount.toFixed(2) %></td>
                        <td>
                            <a href="/dashboard/editExpenseForm/<%= expense._id %>" class="btn" style="font-size: 0.9em; padding: 5px 10px;">Edit</a>
                            <form action="/dashboard/deleteExpense/<%= expense._id %>" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-danger" style="font-size: 0.9em; padding: 5px 10px; border: none; cursor: pointer;">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </table>
        <% } else { %>
            <p>No expenses yet. <a href="/dashboard/expenseForm">Add one now!</a></p>
        <% } %>


        <h2>Budgets for <%= currentMonth %></h2>
        <% if (budgets.length > 0) { %>
            <table>
                <tr>
                    <th>Category</th>
                    <th>Limit</th>
                    <th>Actions</th>
                </tr>
                <% budgets.forEach(budget => { %>
                    <tr>
                        <td><span class="category-tag"><%= budget.category %></span></td>
                        <td>$<%= budget.limit.toFixed(2) %></td>
                        <td>
                            <a href="/dashboard/editBudgetForm/<%= budget._id %>" class="btn" style="font-size: 0.9em; padding: 5px 10px;">Edit</a>
                            <form action="/dashboard/deleteBudget/<%= budget._id %>" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-danger" style="font-size: 0.9em; padding: 5px 10px; border: none; cursor: pointer;">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </table>
        <% } else { %>
            <p>No budgets yet. <a href="/dashboard/expenseForm">Add one now!</a></p>
        <% } %>





        <h2>Category Breakdown</h2>
        <ul>
            <% Object.entries(categoryTotals).forEach(([category, total]) => { %>
                <li><%= category %>: $<%= total.toFixed(2) %></li>
            <% }); %>
        </ul>

        <h2>Budget Breakdown</h2>
        <ul>
            <% Object.entries(budgetCategoryTotals).forEach(([category, total]) => { %>
                <li><%= category %>: $<%= total.toFixed(2) %></li>
            <% }); %>
        </ul>

    </div>
</body>
</html>
